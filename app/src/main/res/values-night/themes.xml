<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.WageTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Muted, darker primary that works as a background without being harsh -->
        <item name="colorPrimary">#4A7CA4</item>
        <item name="colorOnPrimary">#E8EDF4</item>
        <item name="colorPrimaryContainer">#1E3550</item>
        <item name="colorOnPrimaryContainer">#B0CDEB</item>

        <item name="colorSecondary">#4A95A8</item>
        <item name="colorOnSecondary">#D6EEF2</item>

        <item name="colorSurface">@color/surface_card_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_dark</item>
        <item name="colorOutline">@color/outline_dark</item>

        <item name="android:colorBackground">@color/surface_dark</item>
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.WageTracker" parent="Base.Theme.WageTracker" />
</resources>