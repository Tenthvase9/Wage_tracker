<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.WageTracker" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorPrimaryContainer">#D6E4FF</item>
        <item name="colorOnPrimaryContainer">#001A41</item>

        <item name="colorSecondary">#03A9F4</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <item name="colorSurface">@color/surface_card_light</item>
        <item name="colorOnSurface">@color/on_surface_light</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_light</item>
        <item name="colorOutline">@color/outline_light</item>

        <item name="android:colorBackground">@color/surface_light</item>
        <item name="android:statusBarColor">?attr/colorPrimary</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.WageTracker" parent="Base.Theme.WageTracker" />

    <style name="Theme.WageTracker.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.WageTracker</item>
    </style>

    <style name="Widget.WageTracker.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">?attr/colorPrimary</item>
        <item name="titleTextColor">@color/brand_on_primary</item>
        <item name="subtitleTextColor">#E3F2FD</item>
        <item name="navigationIconTint">@color/brand_on_primary</item>
        <item name="iconTint">@color/brand_on_primary</item>
    </style>

    <style name="Widget.WageTracker.MonthNav" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">@color/brand_on_primary</item>
        <item name="iconSize">24dp</item>
    </style>

    <style name="Widget.WageTracker.MonthNavInline" parent="Widget.Material3.Button.IconButton">
        <item name="iconTint">?attr/colorPrimary</item>
        <item name="iconSize">24dp</item>
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="Widget.WageTracker.HeroCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">3dp</item>
        <item name="cardBackgroundColor">?attr/colorPrimary</item>
        <item name="contentPadding">20dp</item>
    </style>

    <style name="Widget.WageTracker.MiniCard" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">14dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">?attr/colorOutline</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>
</resources>