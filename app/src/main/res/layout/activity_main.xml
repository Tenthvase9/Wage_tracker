<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2196F3"
        android:padding="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wage Tracker"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tip Management"
            android:textColor="#BBDEFB"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- Month Selector -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <Button
            android:id="@+id/btnPrevMonth"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="◀"
            android:background="@android:color/transparent"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/tvCurrentMonth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="April 2026"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <Button
            android:id="@+id/btnNextMonth"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="▶"
            android:background="@android:color/transparent"
            android:textColor="#FFFFFF"
            android:textSize="18sp"/>
    </LinearLayout>
    <!-- Add Button Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddRecord"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="+ ADD NEW DAY"
            android:layout_marginEnd="6dp"
            app:cornerRadius="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMarkPaid"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="✓ MONTH PAID"
            android:layout_marginStart="6dp"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
    </LinearLayout>

    <!-- Summary Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MONTHLY SUMMARY"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#666666"/>

            <!-- Total Card Tips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Card Tips:"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/totalCardTips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"/>
            </LinearLayout>

            <!-- Total Cash Tips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Cash Tips:"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/totalCashTips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#4CAF50"/>
            </LinearLayout>
            <!-- Total Card + Cash Tips (New separate row) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Card + Cash Tips:"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#000000"/>

                <TextView
                    android:id="@+id/totalCardCashTips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R0"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"/>
            </LinearLayout>

            <!-- Total Tips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Tips:"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/totalTips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R0"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Total Cash Paid In -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Total Cash Paid In:"
                    android:textSize="13sp"/>

                <TextView
                    android:id="@+id/totalCashPaidIn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R0"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#E0E0E0"
                android:layout_marginVertical="8dp"/>

            <!-- Owed Amount -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#E3F2FD"
                android:padding="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="YOU ARE OWED:"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"/>

                <TextView
                    android:id="@+id/totalOwed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="R0"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#2196F3"/>
            </LinearLayout>
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Table Headers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="8dp"
        android:background="#EEEEEE">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:text="Date"
            android:textStyle="bold"
            android:textSize="11sp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Card"
            android:textStyle="bold"
            android:textSize="11sp"
            android:gravity="end"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cash"
            android:textStyle="bold"
            android:textSize="11sp"
            android:gravity="end"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Paid In"
            android:textStyle="bold"
            android:textSize="11sp"
            android:gravity="end"/>

        <TextView
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:text=""
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

</LinearLayout>